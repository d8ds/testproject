"""
Openwork Japanese Review Sentiment Signal Pipeline
===================================================
Input : polars DataFrame, one column per review dimension (Japanese text)
Output: weekly/daily PIT-correct sentiment signals per (company, trading_date)

Requirements:
    pip install polars fugashi ipadic unidic-lite numpy pandas-market-calendars
"""

from __future__ import annotations

import multiprocessing as mp
import re
from datetime import date, timedelta
from pathlib import Path
from typing import Optional

import numpy as np
import polars as pl

# ---------------------------------------------------------------------------
# 0. Config
# ---------------------------------------------------------------------------

class PipelineConfig:
    # ── columns ──────────────────────────────────────────────────────────────
    COMPANY_COL    : str       = "company_id"
    DATE_COL       : str       = "review_date"   # date the review was submitted
    TEXT_COLUMNS   : list[str] = ["wlb", "long_term_development", "reason_to_quit"]

    # ── lexicon ──────────────────────────────────────────────────────────────
    LEXICON_PATH   : str       = "wago.121808.pn"   # 東工大極性辞書

    # ── scoring ──────────────────────────────────────────────────────────────
    MIN_COVERAGE   : float     = 0.05   # minimum lexicon hit rate to keep a review
    MIN_MATCHED    : int       = 2      # minimum matched sentiment words
    NEGATION_WINDOW: int       = 3      # how many tokens after target to look for negation

    # ── signal construction ──────────────────────────────────────────────────
    HALFLIFE_DAYS  : int       = 180    # exponential decay half-life (days)
    MAX_STALE_DAYS : int       = 180    # null-out signal if no review for this many days
    MIN_REVIEWS    : int       = 5      # min cumulative reviews before emitting signal
    FREQUENCY      : str       = "week" # "week" (Friday) or "day"

    # ── date range ───────────────────────────────────────────────────────────
    START_DATE     : str       = "2010-01-01"
    END_DATE       : str       = "2022-12-31"

    # ── compute ──────────────────────────────────────────────────────────────
    N_WORKERS      : int       = 4
    CHUNK_SIZE     : int       = 2_000


CFG = PipelineConfig()


# ---------------------------------------------------------------------------
# 1. Sentiment lexicon
# ---------------------------------------------------------------------------

